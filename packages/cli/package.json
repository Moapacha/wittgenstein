{
  "name": "@wittgenstein/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "wittgenstein": "./bin/wittgenstein.js"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -b",
    "lint": "eslint src test --ext .ts",
    "test": "vitest run",
    "build": "tsc",
    "bundle": "node scripts/bundle.mjs",
    "release:npm": "node scripts/bundle.mjs && node scripts/prepare-npm-artifact.mjs"
  },
  "dependencies": {
    "@wittgenstein/core": "workspace:*",
    "@wittgenstein/schemas": "workspace:*",
    "commander": "^12.1.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "esbuild": "0.24.2"
  }
}
